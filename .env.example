# RAG 测试项目 - 敏感配置模板
# 此文件为模板，包含所有需要配置的敏感信息
# 请复制此文件为 .env，并填入实际值
# 注意：.env 文件包含敏感信息，不应提交到 git

# ============================================
# 数据库配置（全部视为敏感信息）
# ============================================
# 数据库主机地址
DB_HOST=

# 数据库端口
DB_PORT=

# 数据库用户名
DB_USER=

# 数据库密码
DB_PASSWORD=

# 数据库名称
DB_NAME=

# 向量存储表名
VECTOR_TABLE_NAME=

# 嵌入向量维度（必须与模型匹配）
# 常用模型维度：
#   - text-embedding-v3: 1024
#   - qwen3-vl-embedding: 2560
#   - tongyi-embedding-vision-plus-2026-03-06: 1152
#   - tongyi-embedding-vision-flash-2026-03-06: 768
#   - bge-small-zh-v1.5: 512 (本地中文模型)
EMBEDDING_DIMENSION=

# ============================================
# 自动重建表配置（切换嵌入模型时使用）
# ============================================
# 当切换不同维度的嵌入模型时，已有的向量表维度与新模型不匹配会导致错误。
# 设置为 true 时，系统会自动检测维度不匹配并删除旧表，让系统重新创建。
# 警告：这会删除所有已存储的向量数据！
#
# 使用场景：
#   1. 首次切换到本地模型 bge-small-zh-v1.5 时（从 API 模型切换）
#   2. 切换不同维度的嵌入模型时
#
# 建议：
#   - 切换模型时设置为 true，启动一次后可设置回 false
#   - 或者在 settings.yaml 中配置 database.auto_recreate_table
#
# 可选值: true/false, 1/0, yes/no, on/off
AUTO_RECREATE_TABLE=

# ============================================
# API 密钥配置
# ============================================
# 阿里百炼 API Key
# 请访问 https://dashscope.aliyun.com/ 申请 API Key
DASHSCOPE_API_KEY=

# ============================================
# Flask 安全配置
# ============================================
# Flask 密钥（用于会话管理等）
# 请使用随机字符串
SECRET_KEY=
