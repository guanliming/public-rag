# RAG 测试项目 - 敏感配置模板
# 此文件为模板，包含所有需要配置的敏感信息
# 请复制此文件为 .env，并填入实际值
# 注意：.env 文件包含敏感信息，不应提交到 git

# ============================================
# 数据库敏感配置
# ============================================
# 数据库密码
DB_PASSWORD=

# ============================================
# API 密钥配置
# ============================================
# 阿里百炼 API Key
# 请访问 https://dashscope.aliyun.com/ 申请 API Key
DASHSCOPE_API_KEY=

# ============================================
# Flask 安全配置
# ============================================
# Flask 密钥（用于会话管理等）
# 请使用随机字符串
SECRET_KEY=
