# RAG 测试项目 - 敏感配置模板
# 此文件为模板，包含所有需要配置的敏感信息
# 请复制此文件为 .env，并填入实际值
# 注意：.env 文件包含敏感信息，不应提交到 git

# ============================================
# 数据库配置（全部视为敏感信息）
# ============================================
# 数据库主机地址
DB_HOST=

# 数据库端口
DB_PORT=

# 数据库用户名
DB_USER=

# 数据库密码
DB_PASSWORD=

# 数据库名称
DB_NAME=

# 向量存储表名
VECTOR_TABLE_NAME=

# 嵌入向量维度（必须与模型匹配）
# 常用模型维度：
#   - text-embedding-v3: 1024
#   - qwen3-vl-embedding: 2560
#   - tongyi-embedding-vision-plus-2026-03-06: 1152
#   - tongyi-embedding-vision-flash-2026-03-06: 768
EMBEDDING_DIMENSION=

# ============================================
# API 密钥配置
# ============================================
# 阿里百炼 API Key
# 请访问 https://dashscope.aliyun.com/ 申请 API Key
DASHSCOPE_API_KEY=

# ============================================
# Flask 安全配置
# ============================================
# Flask 密钥（用于会话管理等）
# 请使用随机字符串
SECRET_KEY=
